<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Contact Us</title>
</head>
<body>

    <%- include ('partials/header') %>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->

    <div class="container mt-3">
        <h2>Task Details</h2>
        <form action="/confirm" method="post">
            <div class="mb-3 mt-3">
                <label for="title">Title:</label>
                <input type="text" class="form-control" id="title" placeholder="Enter Task here" name="title">
            </div>
            <div class="mb-3 mt-3">
                <label for="description">Description:</label>
                <input type="text" class="form-control" id="description" placeholder="Enter task description" name="description">
            </div>

            <div class="mb-3 mt-3">
                <label for="deadline">Deadline:</label>
                 <input type="date" class="form-control" id="deadline" placeholder="dd/mm/yyyy" name="deadline">

            </div>

            <div class="mb-3 mt-3">
                <lable for="priority">Priority:</lable>
                <input type="text" class="form-control" id="priority" name="priority">
                
            </div>
            
            <!-- Activity 3: Edit contact.ejs to include more form fields – Contact No. and Comments: -->
            
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>
</body>
</html>